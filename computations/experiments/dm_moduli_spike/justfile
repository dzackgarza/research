export PYTHONDONTWRITEBYTECODE := "1"

# Commit gate: fast pytest only (`@pytest.mark.ci` tests run under test-ci).
export PYTEST_ADDOPTS := "-m 'not ci'"

# Run the full spike test suite via the global Sage QC.
# Test files are .sage so the Sage preparser converts integer literals to
# Sage Integer/Rational before pytest collects them.
test:
    @just -f ~/ai-review-ci/justfiles/sage.just -d . test

# CI gate: full pytest (including ci-marked oracle / enumeration tests).
test-ci:
    #!/usr/bin/env bash
    set -euo pipefail
    export PYTEST_ADDOPTS=""
    just -f ~/ai-review-ci/justfiles/sage.just -d . test-ci
