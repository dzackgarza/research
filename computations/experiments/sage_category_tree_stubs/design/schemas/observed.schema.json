{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sage-observed-manifest.schema.json",
  "title": "Observed Sage category manifest",
  "type": "object",
  "required": ["manifest", "categories", "axioms", "constructions", "aliases"],
  "properties": {
    "manifest": {
      "type": "object",
      "required": ["schema_version", "sage_version", "extractor_version", "generated_at"],
      "properties": {
        "schema_version": { "type": "integer" },
        "sage_version": { "type": "string" },
        "sage_git_commit": { "type": ["string", "null"] },
        "extractor_version": { "type": "string" },
        "generated_at": { "type": "string" },
        "python_version": { "type": ["string", "null"] },
        "inventory_sha256": { "type": ["string", "null"] },
        "scope": { "type": "string" }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "symbol", "module", "qualname"],
        "properties": {
          "id": { "type": "string", "pattern": "^sage\\." },
          "kind": {
            "type": "string",
            "enum": [
              "category_class",
              "category_instance",
              "category_with_axiom",
              "construction_category",
              "join_category",
              "runtime_generated_class",
              "named_wrapper",
              "alias",
              "framework_helper",
              "example_only",
              "test_only"
            ]
          },
          "symbol": { "type": "string" },
          "module": { "type": "string" },
          "qualname": { "type": "string" },
          "parameters": { "type": "array" },
          "representative": { "type": ["object", "null"] },
          "source": { "type": "object" },
          "immediate_supercategories": { "type": "array" },
          "declared_supercategories": { "type": "array" },
          "observed_supercategories": { "type": "array" },
          "defined_axioms": { "type": "array" },
          "available_axioms": { "type": "array" },
          "satisfied_axioms": { "type": "array" },
          "defined_constructions": { "type": "array" },
          "available_constructions": { "type": "array" },
          "aliases": { "type": "array" },
          "deprecated_aliases": { "type": "array" },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "axioms": { "type": "array" },
    "constructions": { "type": "array" },
    "aliases": { "type": "array" }
  }
}
