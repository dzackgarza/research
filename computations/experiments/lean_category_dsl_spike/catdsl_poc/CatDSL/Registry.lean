import CatDSL.Foundation
import Lean

namespace CatDSL.Registry

open Lean Meta Elab
open CatDSL

private def insertPreferred (names : Array Name) (declName : Name) : Array Name :=
  if names.contains declName then names else names.push declName

/--
The preferred-functor edge set.

This must be **enumerable**: path resolution asks for *all* registered
edges, not whether one given declaration is registered.  That rules out a
`TagAttribute`, which exposes only `setTag`/`hasTag` -- a predicate on a
declaration you already name.  Hence a dedicated persistent extension whose
aggregate state is readable via `getState`.

`addImportedFn` rebuilds the set from `.olean` entries, so the graph survives
imports.
-/
initialize preferredFunctorExt :
    SimplePersistentEnvExtension Name (Array Name) ←
  registerSimplePersistentEnvExtension {
    name := `CatDSL.Registry.preferredFunctorExt
    addEntryFn := insertPreferred
    addImportedFn := fun modules =>
      modules.foldl (init := #[]) fun names entries =>
        entries.foldl (init := names) insertPreferred
  }

/-- Every preferred-functor declaration visible in this environment. -/
def preferredFunctorNames (env : Environment) : Array Name :=
  preferredFunctorExt.getState env

/-- Record a declaration as a preferred functor in the current module. -/
def addPreferredFunctor (declName : Name) : CoreM Unit := do
  modifyEnv fun env => preferredFunctorExt.addEntry env declName

/--
Recover the category of definition of a DSL object from its Lean type.

Every declaration generated by `let X ∈ C` or `let X := t ∈ C` has type
`CatDSL.Object C`.  Keeping `Object` as a transparent definition rather
than an abbreviation preserves this head symbol in the declaration
type, eliminating the need for a parallel object registry.
-/
def objectHome (declName : Name) : MetaM Expr := do
  let info ← getConstInfo declName
  let ty ← instantiateMVars info.type
  if ty.isAppOfArity ``CatDSL.Object 1 then
    return ty.getAppArgs[0]!
  throwError
    "declaration '{declName}' is not a DSL object; its type is\n  {ty}"

structure Step where
  declName : Name
  functorExpr : Expr
  source : Expr
  target : Expr
  deriving Inhabited

structure Path where
  source : Expr
  target : Expr
  steps : Array Step := #[]

/--
The single place that knows how Mathlib represents a functor.

`CategoryTheory.Functor` takes four arguments -- source type, source
`Category` instance, target type, target instance:

    Functor : (C : Type u) → [Category.{v} C] → (D : Type u') → [Category.{v'} D] → Type _

A graph node is the **bundled** `Cat.of C inst`, not the bare type: Lean can
carry two different `Category` instances on one type, and those are two
different categories.  Bundling also makes nodes directly comparable with
what `objectHome` returns, which is a `Cat`.
-/
def inspectFunctorType? (body : Expr) : MetaM (Option (Expr × Expr)) := do
  let body ← whnf body
  unless body.isAppOfArity ``CategoryTheory.Functor 4 do
    return none
  let args := body.getAppArgs
  -- `Cat.of (C) [Category C]` takes the instance as INSTANCE-IMPLICIT, so
  -- `mkAppM` (explicit args only) rejects it. `mkAppOptM` supplies both, and
  -- passing the instance explicitly matters: resolving it instead could pick
  -- a different `Category` structure on the same type.
  let sourceCat ← mkAppOptM ``CategoryTheory.Cat.of #[some args[0]!, some args[1]!]
  let targetCat ← mkAppOptM ``CategoryTheory.Cat.of #[some args[2]!, some args[3]!]
  return some (sourceCat, targetCat)

private def sameCategory (a b : Expr) : MetaM Bool := do
  let saved ← saveState
  try
    let ok ← isDefEq a b
    saved.restore
    return ok
  catch _ =>
    saved.restore
    return false

/--
Instantiate a registered preferred functor family against a concrete
source category.

Example:

```
FreeFinModule.toFiniteSet :
  (R : FiniteRingObj) →
  Functor (FreeFinModules R) FiniteSets
```

When the current category is `FreeFinModules 𝔽₂`, Lean unification
recovers `R := 𝔽₂` and constructs the instantiated functor.
-/
private def instantiateEdge?
    (declName : Name) (actualSource : Expr) :
    MetaM (Option Step) := do
  let fn ← mkConstWithFreshMVarLevels declName
  let fnType ← inferType fn
  -- `forallMetaTelescopeReducing` returns a tuple; it is not CPS.
  let (params, _, body) ← forallMetaTelescopeReducing fnType
  let some (edgeSource, edgeTarget) ← inspectFunctorType? body
    | return none
  let saved ← saveState
  unless ← isDefEq edgeSource actualSource do
    saved.restore
    return none
  let applied ← instantiateMVars (mkAppN fn params)
  let source ← instantiateMVars edgeSource
  let target ← instantiateMVars edgeTarget
  if applied.hasMVar || target.hasMVar then
    saved.restore
    return none
  return some {
    declName := declName
    functorExpr := applied
    source := source
    target := target
  }

private structure SearchNode where
  category : Expr
  steps : Array Step
  deriving Inhabited

private def sameAsAny (visited : Array Expr) (C : Expr) : MetaM Bool := do
  for D in visited do
    if ← sameCategory C D then
      return true
  return false

/--
Breadth-first reachability in the preferred-functor graph.

Membership `X ∈ C` is existential reachability.  The first shortest path
is retained only to elaborate the corresponding object term and to
report provenance.
-/
partial def resolvePath
    (source target : Expr) (maxDepth : Nat := 16) :
    MetaM Path := do
  if ← sameCategory source target then
    return { source, target, steps := #[] }

  let edgeNames := preferredFunctorNames (← getEnv)

  let mut queue : Array SearchNode :=
    #[{ category := source, steps := #[] }]
  let mut cursor := 0
  let mut visited : Array Expr := #[source]

  while cursor < queue.size do
    let node := queue[cursor]!
    cursor := cursor + 1

    if node.steps.size < maxDepth then
      for edgeName in edgeNames do
        if let some step ← instantiateEdge? edgeName node.category then
          let newSteps := node.steps.push step
          if ← sameCategory step.target target then
            return { source, target, steps := newSteps }
          unless ← sameAsAny visited step.target do
            visited := visited.push step.target
            queue := queue.push {
              category := step.target
              steps := newSteps
            }

  throwError
    "no preferred-functor path was found from\n  {source}\nto\n  {target}"

def applyPath (path : Path) (objectExpr : Expr) : MetaM Expr := do
  let mut result := objectExpr
  for step in path.steps do
    result ← mkAppM ``CategoryTheory.Functor.obj #[step.functorExpr, result]
  instantiateMVars result

def pathNames (path : Path) : Array Name :=
  path.steps.map (·.declName)

/--
Reject a declaration that is not a functor, nor a parameterized family
whose eventual result is a functor.  This is what makes an unsupported
edge such as `Mod(R) ↝ Ring` fail at `prefer` time rather than silently
entering the graph.
-/
def checkPreferredFunctor (declName : Name) : MetaM Unit := do
  let fn ← mkConstWithFreshMVarLevels declName
  let fnType ← inferType fn
  let (_, _, body) ← forallMetaTelescopeReducing fnType
  unless (← inspectFunctorType? body).isSome do
    throwError
      "declaration '{declName}' cannot be preferred: after introducing \
       all parameters its result type is\n  {body}\nbut a functor \
       `C ⥤ D` was expected"

end CatDSL.Registry
