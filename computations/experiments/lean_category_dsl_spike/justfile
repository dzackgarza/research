# Lean category-DSL spike.
#
# Lake / mathlib live at the **repository root** (not here):
#   lean-toolchain, lakefile.toml, .lake/
#
# Surfaces (srcDir under root lakefile):
#   NormalizedCategoryGraph — expression kernel + export (primary)
#   LeanCategoryDslSpike/     finite-pair numbering lemma
#   catdsl_poc/               CatDSL PoC (BFS registry — to be retired for hierarchy)
#
# From this directory, recipes `cd` to the repo root for lake. Prefer:
#   just -f justfile setup|cache|build|test
# or run the same targets from the repo root once a root justfile exists.

spike_dir := justfile_directory()
# Evaluated from the justfile directory (spike); resolves the monorepo root.
repo_root := `git rev-parse --show-toplevel`

# List available recipes
default:
    @just --list

# Verify the toolchain is the official build (mathlib's cache depends on it)
setup:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{repo_root}}"
    if ! command -v elan >/dev/null; then
      echo "elan not found. Install the AUR package 'elan-lean' (not 'elan')." >&2
      exit 1
    fi
    if pacman -Qq lean >/dev/null 2>&1; then
      echo "a distro 'lean' package is installed; it will fight elan's shim." >&2
      echo "remove it: pacman -R lean" >&2
      exit 1
    fi
    ours=$(lean --version | grep -oE '[0-9a-f]{40}')
    theirs=$(gh api repos/leanprover/lean4/commits/v4.32.0 --jq .sha 2>/dev/null || echo unknown)
    echo "lean githash : $ours"
    echo "v4.32.0      : $theirs"
    if [ "$ours" != "$theirs" ] && [ "$theirs" != "unknown" ]; then
      echo "MISMATCH -- not the official build; mathlib's cache will not apply." >&2
      exit 1
    fi
    echo "ok: official toolchain, cache will apply (repo-root Lake workspace)"

# Fetch mathlib's prebuilt oleans (single root workspace)
cache:
    cd "{{repo_root}}" && lake exe cache get

# Build all Lean libraries / export exes
build:
    cd "{{repo_root}}" && lake build NormalizedCategoryGraph LeanCategoryDslSpike CatDSL ncg-export-full

[private]
_ncg-module module:
    cd "{{repo_root}}" && lake build +{{module}}

# Regenerate Python migration manifest + DOT sidecar (oracle / comparison — not Lean SSOT)
gen-seed:
    python3 scripts/generate_seed_spec.py

# Python-seed crosscheck + constructibility oracle (does NOT prove Lean authority)
ncg-check-python-oracle: gen-seed
    python3 scripts/crosscheck_hand_dot.py
    PYTHONPATH=../sage_category_tree_stubs sage -python scripts/ledger_check_from_lean_manifest.py

# Lean exporters must succeed without Python semantic-seed data; ledger is noncircular
ncg-check-lean:
    #!/usr/bin/env bash
    set -euo pipefail
    root="{{repo_root}}"
    cd "$root"
    lake build NormalizedCategoryGraph.Realization.Sage.Correspondence ncg-export-full
    lake exe ncg-export-full | python3 "{{spike_dir}}/scripts/ledger_check_from_lean_export.py"
    "$root/.lake/build/bin/ncg-export-full" | python3 "{{spike_dir}}/scripts/ledger_check_from_lean_export.py"

# Prefer Lean check; Python oracle remains available explicitly
ncg-check: ncg-check-lean

# Run the proof surface: Lean build + Lean exporters (+ optional Python oracle)
test: build ncg-check
    #!/usr/bin/env bash
    set -euo pipefail
    root="{{repo_root}}"
    "$root/.lake/build/bin/ncg-export-full" >/dev/null
    cd "$root" && lake build CatDSLTest

# Everything, from a cold checkout
test-ci: setup cache test

# Target-private implementation consumed by ai-review-ci's shared Lean recipe.
_lean-axiom-audit:
    cd "{{repo_root}}" && lake env lean "{{spike_dir}}/LeanAxiomAudit.lean"

# Run the shared kernel-axiom audit directly when inspecting Lean work.
axioms:
    @just -f ~/ai-review-ci/justfiles/lean.just -d "{{repo_root}}" lean-axiom-audit

# Remove build artifacts; mathlib packages stay until `rm -rf {{repo_root}}/.lake`
clean:
    rm -rf "{{repo_root}}/.lake/build"
