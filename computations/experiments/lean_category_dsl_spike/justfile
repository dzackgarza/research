# Lean category-DSL spike.
#
# Two Lean projects, both pinned to leanprover/lean4:v4.32.0 + mathlib v4.32.0:
#
#   .            LeanCategoryDslSpike — the finite-pair numbering lemma
#   catdsl_poc/  CatDSL — the categorical DSL proof of concept
#
# Setup is elan, and it is not optional. Run `just setup` first.

# List available recipes
default:
    @just --list

# Verify the toolchain is the official build (mathlib's cache depends on it)
setup:
    #!/usr/bin/env bash
    # Mathlib ships a BINARY cache keyed to the exact official toolchain build:
    # Lake's traces include the Lean githash. A distro/AUR `lean` has a
    # different githash, so the cache silently never applies and every build
    # recompiles all ~7900 modules. The failure is invisible -- `cache get`
    # "succeeds", the build "works", it is just permanently slow.
    #
    # Install per the Arch Wiki's Lean 4 section: AUR `elan-lean` -- NOT `elan`,
    # which is the ELAN video-annotation tool. Remove any `lean` package so it
    # cannot win the PATH. elan reads each project's lean-toolchain itself.
    set -euo pipefail
    if ! command -v elan >/dev/null; then
      echo "elan not found. Install the AUR package 'elan-lean' (not 'elan')." >&2
      exit 1
    fi
    if pacman -Qq lean >/dev/null 2>&1; then
      echo "a distro 'lean' package is installed; it will fight elan's shim." >&2
      echo "remove it: pacman -R lean" >&2
      exit 1
    fi
    ours=$(lean --version | grep -oE '[0-9a-f]{40}')
    theirs=$(gh api repos/leanprover/lean4/commits/v4.32.0 --jq .sha 2>/dev/null || echo unknown)
    echo "lean githash : $ours"
    echo "v4.32.0      : $theirs"
    if [ "$ours" != "$theirs" ] && [ "$theirs" != "unknown" ]; then
      echo "MISMATCH -- not the official build; mathlib's cache will not apply." >&2
      exit 1
    fi
    echo "ok: official toolchain, cache will apply"

# Fetch mathlib's prebuilt oleans for both projects
cache:
    # The honesty check: if this is honoured, the builds below compile ZERO
    # mathlib modules. Any `Built Mathlib.*` line means the cache was
    # rejected -- re-run `just setup`.
    lake exe cache get
    cd catdsl_poc && lake exe cache get

# Build both libraries
build:
    lake build
    cd catdsl_poc && lake build CatDSL

# Run the proof surface: |L| = 4, the registry, the DSL syntax
test: build
    # lemma project  finite-pair numbering: number/unnumber form an Equiv
    # CatDSL         |L| = 4, number (a,b) = 2a+b, nth inverts number, the
    #                registry finding the F₂ path itself, and the surface
    #                let/prefer/#via actually running
    cd catdsl_poc && lake build CatDSLTest

# Everything, from a cold checkout
test-ci: setup cache test

# Audit the proofs: no sorry, standard axioms only
axioms:
    #!/usr/bin/env bash
    set -euo pipefail
    if rg -n 'sorry|admit' --glob '*.lean' LeanCategoryDslSpike catdsl_poc/CatDSL; then
      echo "sorry/admit found above" >&2
      exit 1
    fi
    cd catdsl_poc
    cat > /tmp/catdsl-axioms.lean <<'LEAN'
    import CatDSL.Example.F2Semantic
    open CatDSL.Example
    #print axioms card_L
    #print axioms number_table
    #print axioms nth_table
    #print axioms nth_number_L
    LEAN
    lake env lean /tmp/catdsl-axioms.lean
    echo "expect only: propext, Classical.choice, Quot.sound"

# Remove build artifacts (~20G); mathlib is re-fetched from cache, not rebuilt
clean:
    rm -rf .lake/build catdsl_poc/.lake/build
