# Base Sage lattice-category spike.
#
# The root repository `just test` runs umbrella hygiene and then delegates here.
# This local recipe owns the spike's test layout so maintenance work does not
# need to know the root justfile internals.

# No bytecode litter: the root `just test` hygiene sweep rejects __pycache__.
export PYTHONDONTWRITEBYTECODE := "1"

# Run the full base-spike test suite.
test:
    sage -python -m pytest -p no:cacheprovider {{justfile_directory()}}/tests

# CI alias for the same proof surface.
test-ci: test
