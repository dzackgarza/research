// Siting-enforcement checker (#100 T4): flaggability, not prevention.
// Only reportPrivateUsage is enabled -- a private reach outside its
// sanctioned scope is a type-check finding routed to the audit/disposition
// workflow. All other type checking is owned by mypy (the just test gate)
// and the lexicon check. The sage_patches subtree is the one sanctioned
// crossing point for Sage-boundary reaches (each ruled-in Sage-private
// engine is one documented module there), so it is excluded by name.
{
  "typeCheckingMode": "off",
  "include": ["."],
  "exclude": ["**/tests", "typings", "**/__pycache__", "sage_patches"],
  "stubPath": "typings",
  "reportPrivateUsage": "error"
}
