# Repo-scoped stubs; see lexicon/README.md. A factorization is the finite
# family of (prime, multiplicity) pairs together with a unit; iteration
# yields the pairs (the multiplicity is a plain Python int in Sage).
from collections.abc import Iterator

from sage.rings.integer import Integer

class Factorization:
    def __iter__(self) -> Iterator[tuple[Integer, int]]: ...
    def __getitem__(self, i: int) -> tuple[Integer, int]: ...
    def __len__(self) -> int: ...
    def unit(self) -> Integer: ...
