# General mathematical contract for Sage's element hierarchy, verified by
# lexicon/verify_against_sage.py. The linear-algebra classes are generic in
# their scalar (any RingElement regime: exact, symbolic, p-adic, real, ...);
# the type parameter DEFAULTS to the exact ZZ/QQ regime this repo computes in,
# so bare `Matrix`/`Vector` mean exact matrices and future regimes are spelled
# `Matrix[Expression]` etc. rather than re-golfed (lexicon/INVENTORY.md III).
import builtins
from collections.abc import Iterator, Sequence
from typing import Any, Generic, overload

from typing_extensions import Self, TypeVar

from sage.categories.rings import Rings
from sage.modules.free_module import FreeModule_generic
from sage.rings.integer import Integer
from sage.rings.rational import Rational
from sage.structure.parent import Parent

class Element:
    def __init__(self, parent: Parent) -> None: ...
    def parent(self) -> Parent: ...
    # Arithmetic enters through the coercion model on Element itself; negation
    # is parent-preserving.
    def __neg__(self) -> Self: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class ModuleElement(Element): ...

class MonoidElement(Element): ...

class MultiplicativeGroupElement(MonoidElement): ...

class RingElement(ModuleElement):
    # An element of a ring has a ring parent (category-first: the parent's
    # type is the category's ParentMethods; INVENTORY.md II.2).
    def parent(self) -> Rings.ParentMethods: ...
    def __add__(self, other: RingElement) -> RingElement: ...
    def __mul__(self, other: Any) -> Any: ...
    def __rmul__(self, other: Any) -> Any: ...
    def __abs__(self) -> Self: ...
    def __lt__(self, other: object) -> bool: ...
    def __le__(self, other: object) -> bool: ...
    def __gt__(self, other: object) -> bool: ...
    def __ge__(self, other: object) -> bool: ...

_Scalar = TypeVar("_Scalar", bound=RingElement, default=Integer | Rational)

class Vector(ModuleElement, Generic[_Scalar]):
    # Sage vectors iterate through the legacy __getitem__/__len__ protocol;
    # the __iter__ claim states the mathematical truth (a coordinate vector is
    # a finite family of scalars) and is verified by probing iter() on a
    # representative instance, not by dir().
    def __iter__(self) -> Iterator[_Scalar]: ...
    def __len__(self) -> int: ...
    def __getitem__(self, i: int | Integer) -> _Scalar: ...
    def __neg__(self) -> Vector[_Scalar]: ...
    def __add__(self, other: Vector[_Scalar]) -> Vector[_Scalar]: ...
    def __sub__(self, other: Vector[_Scalar]) -> Vector[_Scalar]: ...
    @overload
    def __mul__(self, other: Matrix[_Scalar]) -> Vector[_Scalar]: ...
    @overload
    def __mul__(self, other: Vector[_Scalar]) -> _Scalar: ...
    @overload
    def __mul__(self, other: int | _Scalar) -> Vector[_Scalar]: ...
    def __rmul__(self, other: int | _Scalar) -> Vector[_Scalar]: ...
    def set_immutable(self) -> None: ...
    def __setitem__(self, i: int | Integer, value: object) -> None: ...
    def list(self) -> builtins.list[_Scalar]: ...
    def denominator(self) -> Integer: ...

class Matrix(ModuleElement, Generic[_Scalar]):
    def nrows(self) -> int: ...
    def ncols(self) -> int: ...
    def rank(self) -> int: ...
    def det(self) -> _Scalar: ...
    def determinant(self) -> _Scalar: ...
    def transpose(self) -> Matrix[_Scalar]: ...
    def inverse(self) -> Matrix[_Scalar]: ...
    def is_square(self) -> bool: ...
    def is_symmetric(self) -> bool: ...
    def is_invertible(self) -> bool: ...
    def set_immutable(self) -> None: ...
    def is_immutable(self) -> bool: ...
    def change_ring(self, ring: Parent) -> Matrix[Any]: ...
    def list(self) -> builtins.list[_Scalar]: ...
    def diagonal(self) -> builtins.list[_Scalar]: ...
    def rows(self) -> builtins.list[Vector[_Scalar]]: ...
    def columns(self) -> builtins.list[Vector[_Scalar]]: ...
    def row(self, i: int | Integer) -> Vector[_Scalar]: ...
    def column(self, j: int | Integer) -> Vector[_Scalar]: ...
    def stack(self, other: Matrix[_Scalar] | Vector[_Scalar]) -> Matrix[_Scalar]: ...
    def matrix_from_columns(self, columns: Sequence[int]) -> Matrix[_Scalar]: ...
    def augment(self, other: Matrix[_Scalar] | Vector[_Scalar]) -> Matrix[_Scalar]: ...
    def tensor_product(self, other: Matrix[_Scalar]) -> Matrix[_Scalar]: ...
    def right_kernel(self) -> FreeModule_generic[_Scalar]: ...
    def left_kernel(self) -> FreeModule_generic[_Scalar]: ...
    def row_space(self) -> FreeModule_generic[_Scalar]: ...
    def LLL_gram(self) -> Matrix[Integer]: ...
    def smith_form(self) -> tuple[Matrix[_Scalar], Matrix[_Scalar], Matrix[_Scalar]]: ...
    def elementary_divisors(self) -> builtins.list[Integer]: ...
    def solve_left(self, other: Matrix[_Scalar] | Vector[_Scalar]) -> Any: ...
    def solve_right(self, other: Matrix[_Scalar] | Vector[_Scalar]) -> Any: ...
    def apply_map(self, f: Any) -> Matrix[Any]: ...
    def denominator(self) -> Integer: ...
    def __neg__(self) -> Matrix[_Scalar]: ...
    def __add__(self, other: Matrix[_Scalar]) -> Matrix[_Scalar]: ...
    def __sub__(self, other: Matrix[_Scalar]) -> Matrix[_Scalar]: ...
    @overload
    def __mul__(self, other: Matrix[_Scalar]) -> Matrix[_Scalar]: ...
    @overload
    def __mul__(self, other: Vector[_Scalar]) -> Vector[_Scalar]: ...
    @overload
    def __mul__(self, other: int | _Scalar) -> Matrix[_Scalar]: ...
    def __rmul__(self, other: int | _Scalar) -> Matrix[_Scalar]: ...
    def __pow__(self, n: int | Integer) -> Matrix[_Scalar]: ...
    def __getitem__(self, key: tuple[int | Integer, int | Integer]) -> _Scalar: ...
    def __setitem__(self, key: tuple[int | Integer, int | Integer], value: object) -> None: ...
