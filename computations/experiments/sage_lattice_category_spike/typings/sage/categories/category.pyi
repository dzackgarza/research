# Repo-scoped stubs; see lexicon/README.md. Sage's category framework is
# deeply dynamic (axiom methods are synthesized); the stub types the static
# skeleton the repo subclasses and leaves the dynamic surface to the
# subclasses' own declarations.
from typing import Any

class Category:
    def __call__(self, *args: Any, **kwds: Any) -> Any: ...
    def super_categories(self) -> list[Category]: ...
    def is_subcategory(self, other: Category) -> bool: ...
    def _meet_(self, other: Category) -> Category: ...
    def __contains__(self, x: object) -> bool: ...
    def axioms(self) -> frozenset[str]: ...
    def _with_axiom(self, axiom: str) -> Category: ...
    def Finite(self) -> Category: ...
    def Infinite(self) -> Category: ...
    def Homsets(self) -> Category: ...
