source "$HOME/.envrc"

# Sage QC (~/ai-review-ci/justfiles/sage.just) requires the Sage executable path.
export SAGE_BIN="${SAGE_BIN:-$(command -v sage)}"

export RESEARCH_EXPERIMENTS="$PWD/computations/experiments"
case ":${PYTHONPATH:-}:" in
  *":$RESEARCH_EXPERIMENTS:"*) ;;
  *) export PYTHONPATH="$RESEARCH_EXPERIMENTS${PYTHONPATH:+:$PYTHONPATH}" ;;
esac

export RESEARCH_SOURCE="$PWD/src"
case ":${PYTHONPATH:-}:" in
  *":$RESEARCH_SOURCE:"*) ;;
  *) export PYTHONPATH="$RESEARCH_SOURCE${PYTHONPATH:+:$PYTHONPATH}" ;;
esac

# The base spike owns the Sage type surface.  Root-level mypy also checks the
# workspace package, so make that existing stub tree available before the
# global QC config's root-relative `typings` fallback.
export RESEARCH_SAGE_STUBS="$PWD/computations/experiments/sage_lattice_category_spike/typings"
case ":${MYPYPATH:-}:" in
  *":$RESEARCH_SAGE_STUBS:"*) ;;
  *) export MYPYPATH="$RESEARCH_SAGE_STUBS${MYPYPATH:+:$MYPYPATH}" ;;
esac
