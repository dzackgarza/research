{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd",
        "--context",
        ".serena/contexts/obsidian-inbox-analysis.yml",
        "--mode",
        ".serena/modes/obsidian-inbox-analysis.yml",
        "--enable-web-dashboard",
        "false",
        "--enable-gui-log-window",
        "false",
        "--open-web-dashboard",
        "false"
      ]
    }
  }
}
